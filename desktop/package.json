{
  "name": "claudeorb",
  "productName": "ClaudeOrb",
  "version": "1.0.5",
  "description": "Mac menubar companion app for Claude Code usage stats",
  "author": "Alexander Herbst",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.claudeorb.app",
    "productName": "ClaudeOrb",
    "mac": {
      "icon": "assets/icon.icns"
    },
    "dmg": {
      "artifactName": "ClaudeOrb-arm64.dmg"
    },
    "publish": {
      "provider": "github",
      "owner": "SoDyNoTe",
      "repo": "ClaudeOrb"
    }
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "menubar": "^9.4.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1"
  }
}
