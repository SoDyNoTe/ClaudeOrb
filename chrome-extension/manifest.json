{
  "manifest_version": 3,
  "name": "ClaudeOrb",
  "version": "1.0.0",
  "description": "Monitor your Claude AI session and weekly usage limits in real-time.",

  "permissions": ["storage", "notifications", "alarms", "tabs", "windows", "scripting"],
  "host_permissions": ["https://claude.ai/*", "http://localhost:3000/*"],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "ClaudeOrb",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "claudeorb@extension",
      "strict_min_version": "128.0"
    }
  }
}
